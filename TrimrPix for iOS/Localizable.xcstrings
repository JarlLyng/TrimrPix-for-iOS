    },
    "Double tap to start compressing. This replaces original photos and cannot be undone." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Dobbelttryk for at starte komprimering. Dette erstatter de originale billeder og kan ikke fortrydes." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Doppeltippen, um die Komprimierung zu starten. Dies ersetzt die Originalfotos und kann nicht rückgängig gemacht werden." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Touchez deux fois pour lancer la compression. Cela remplace les photos originales et est irréversible." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ダブルタップで圧縮を開始します。元の写真が置き換えられ、取り消せません。" } }
      }
    },
    "Each photo is compressed to about this size or smaller. Photos already smaller are left unchanged." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Hvert billede komprimeres til omkring denne størrelse eller mindre. Billeder, der allerede er mindre, ændres ikke." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Jedes Foto wird auf etwa diese Größe oder kleiner komprimiert. Bereits kleinere Fotos bleiben unverändert." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Chaque photo est compressée à environ cette taille ou moins. Les photos déjà plus petites ne sont pas modifiées." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "各写真はこのサイズ前後かそれ以下に圧縮されます。すでに小さい写真は変更されません。" } }
      }
    },
