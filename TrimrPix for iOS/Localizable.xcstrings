      }
    },
    "TrimrPix needs full access to your photo library to compress and replace photos. Please enable access in Settings." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "TrimrPix kræver fuld adgang til dit fotobibliotek for at komprimere og erstatte billeder. Aktivér adgang i Indstillinger." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "TrimrPix benötigt vollen Zugriff auf deine Mediathek, um Fotos zu komprimieren und zu ersetzen. Bitte aktiviere den Zugriff in den Einstellungen." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "TrimrPix a besoin d'un accès complet à votre photothèque pour compresser et remplacer les photos. Veuillez activer l'accès dans Réglages." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "写真の圧縮と置き換えには、TrimrPixが写真ライブラリへのフルアクセスを必要とします。設定でアクセスを許可してください。" } }
      }
    },
    "Try a different format or quality level" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Prøv et andet format eller kvalitetsniveau" } },
