      }
    },
    "Choose the photos you want to compress from your library" : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Vælg de billeder fra dit bibliotek, du vil komprimere" } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wähle die Fotos aus deiner Mediathek, die du komprimieren möchtest" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Choisissez les photos de votre photothèque à compresser" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "ライブラリから圧縮したい写真を選んでください" } }
      }
    },
    "Choose which metadata to keep. Disabled items will be permanently removed." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "Vælg hvilke metadata der skal bevares. Fravalgte data fjernes permanent." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Wähle, welche Metadaten erhalten bleiben. Deaktivierte Einträge werden dauerhaft entfernt." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Choisissez les métadonnées à conserver. Les éléments désactivés seront supprimés définitivement." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "保持するメタデータを選択してください。オフにした項目は完全に削除されます。" } }
      }
    },
    "Compress" : {
      "localizations" : {
