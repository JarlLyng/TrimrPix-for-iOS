      }
    },
    "The original photos will be replaced with compressed versions. This cannot be undone." : {
      "localizations" : {
        "da" : { "stringUnit" : { "state" : "translated", "value" : "De originale billeder erstattes med komprimerede versioner. Dette kan ikke fortrydes." } },
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Originalfotos werden durch komprimierte Versionen ersetzt. Dies kann nicht rückgängig gemacht werden." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Les photos originales seront remplacées par des versions compressées. Cette action est irréversible." } },
